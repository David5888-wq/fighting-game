# Игнорируемые файлы
node_modules/    # Зависимости npm (устанавливаются автоматически)
.env            # Файл с паролями/ключами
*.log           # Лог-файлы
.DS_Store       # Служебные файлы macOS
Thumbs.db       # Служебные файлы Windows
/img/*.psd      # Исходники Photoshop
/img/*.tmp      # Временные файлы
